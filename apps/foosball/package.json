    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@typescript/native-preview": "beta",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "vite": "^7.1.2",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "^3.2.4"

{
  "name": "@foos/foosball",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "VITE_MOCK_DATA=true vite",
    "build": "tsgo -b && vite build",
